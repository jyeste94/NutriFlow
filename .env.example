# Copy this file to .env.local and set your machine-specific values.
# Do not commit real secrets.

APP_ENV=dev
APP_SECRET=change_me
DATABASE_URL="mysql://root:@127.0.0.1:3306/nutriflow?serverVersion=8.0&charset=utf8mb4"

# Regex for allowed frontend origins in CORS
# Example for local + Vercel preview/prod:
# CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$|^https://.*\.vercel\.app$|^https://tu-dominio\.com$'
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Optional: override Firebase service account file path
# If omitted, config/services.yaml falls back to:
# %kernel.project_dir%/config/firebase_credentials.local.json
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase_credentials.json
